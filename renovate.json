{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>happyvertical/renovate-config:default"],
  "packageRules": [
    {
      "description": "Automerge minor and patch updates on green PRs",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
