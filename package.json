{
  "name": "@happyvertical/spider",
  "version": "1.1.11",
  "description": "Lightweight web scraping and HTML content extraction using cheerio, happy-dom, and undici for high-performance server-side operations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11.13.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/happyvertical/spider.git"
  },
  "bugs": {
    "url": "https://github.com/happyvertical/spider/issues"
  },
  "homepage": "https://github.com/happyvertical/spider#readme",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./platform": {
      "types": "./dist/platform/index.d.ts",
      "import": "./dist/platform/index.js",
      "default": "./dist/platform/index.js"
    }
  },
  "scripts": {
    "test": "vitest run --testTimeout 120000",
    "test:coverage": "vitest run --coverage --testTimeout 120000",
    "test:watch": "vitest --testTimeout 120000",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "deps:public:check": "node scripts/check-public-dependencies.mjs",
    "docs:api": "typedoc",
    "docs:api:check": "pnpm docs:api && git diff --exit-code -- docs/api && test -z \"$(git ls-files --others --exclude-standard -- docs/api)\"",
    "format": "biome format --write src/",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "npm run build:watch & npm run test:watch",
    "changeset": "changeset",
    "changeset:auto": "npx tsx scripts/auto-changeset.ts",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@happyvertical/cache": "^0.74.8",
    "@happyvertical/utils": "^0.74.8",
    "cheerio": "^1.2.0",
    "crawlee": "^3.17.0",
    "happy-dom": "^20.10.6",
    "playwright": "~1.61.0",
    "undici": "^8.5.0"
  },
  "peerDependencies": {
    "cloakbrowser": "^0.4.0"
  },
  "peerDependenciesMeta": {
    "cloakbrowser": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "4.1.10",
    "lefthook": "2.1.10",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "4.1.10"
  }
}
